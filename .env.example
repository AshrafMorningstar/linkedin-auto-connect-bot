# ============================================================
# LinkedIn Auto-Connect Bot - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER share or commit the .env file to version control!
# ============================================================

# Your LinkedIn email address
LINKEDIN_EMAIL=your_email@example.com

# Your LinkedIn password
LINKEDIN_PASSWORD=your_password_here

# (Optional) Custom search URL for finding people to connect with
# Leave empty to use LinkedIn's default "People You May Know"
# Example: https://www.linkedin.com/search/results/people/?keywords=software+engineer
SEARCH_URL=

# (Optional) Custom note to send with connection requests (max 300 chars)
# Leave empty to send connections without a note
CONNECT_NOTE=Hi! I'd love to connect and expand our professional networks.
# (Optional) Extra keywords to boost profile score (comma-separated)
# These will give a +15 score boost if found in the person's title/bio
# Example: PHP, Python, React, Cloud, AI
HIGH_PROFILE_KEYWORDS=AI, Developer, Investor
